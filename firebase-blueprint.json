{
  "entities": {
    "Chat": {
      "title": "Chat",
      "description": "A conversation between a user and the AI",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "messages": { 
          "type": "array",
          "description": "List of message objects",
          "items": { "type": "object" }
        },
        "pinned": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "messages", "createdAt"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "User preferences and identity",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "userName": { "type": "string" },
        "userPfp": { "type": "string" },
        "settings": { "type": "object" }
      },
      "required": ["uid", "userName"]
    }
  },
  "firestore": {
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "User chat documents"
    },
    "/userProfiles/{userId}": {
      "schema": "UserProfile",
      "description": "Individual user preferences"
    }
  }
}
